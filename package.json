{
  "name": "github-release",
  "version": "4.4.0",
  "description": "A GitHub Action that creates a Github release with file upload and automatically generated release notes.",
  "author": "Yakuhzi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yakuhzi/action-release.git"
  },
  "type": "module",
  "exports": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node --env-file=.env ./dist/index.js",
    "start:dev": "npx @github/local-action . src/main.ts .env",
    "release": "./release.sh",
    "lint": "eslint .",
    "format": "prettier --write .",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@actions/core": "^2.0.1",
    "@actions/github": "^6.0.1",
    "axios": "^1.13.2",
    "firebase-admin": "^13.6.0",
    "mime": "^3.0.0",
    "semver": "^7.7.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/mime": "^3.0.0",
    "@types/node": "^25.0.3",
    "@types/semver": "^7.7.1",
    "@typescript-eslint/eslint-plugin": "^8.50.0",
    "@typescript-eslint/parser": "^8.50.0",
    "eslint": "^9.39.2",
    "globals": "^16.5.0",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
